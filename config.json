{
  "name": "Octo MQTT",
  "version": "1.0.0",
  "slug": "octo-mqtt",
  "description": "A Home Assistant add-on to enable controlling Octo actuators star version 2.",
  "url": "https://github.com/bramboe/octo-mqtt",
  "startup": "application",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "boot": "auto",
  "services": ["mqtt:need"],
  "host_network": false,
  "ports": {
    "1883/tcp": null
  },
  "ports_description": {
    "1883/tcp": "MQTT broker port (only needed if not using Home Assistant's MQTT broker)"
  },
  "map": ["config:ro"],
  "init": false,
  "protection": true,
  "privileged": [],
  "apparmor": true,
  "auth_api": true,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:bed",
  "panel_title": "Octo MQTT",
  "options": {
    "mqtt_host": "<auto_detect>",
    "mqtt_port": "<auto_detect>",
    "mqtt_user": "<auto_detect>",
    "mqtt_password": "<auto_detect>",
    "type": "octo",
    "octoDevices": [
      {
        "name": "RC2",
        "friendlyName": "Octo Bed",
        "pin": "1234"
      }
    ],
    "scannerDevices": []
  },
  "schema": {
    "mqtt_host": "str",
    "mqtt_port": "str",
    "mqtt_user": "str",
    "mqtt_password": "password",
    "type": "list(octo|scanner)",
    "sleeptrackerRefreshFrequency": "int(0,)",
    "sleeptrackerCredentials": [
      {
        "email": "email",
        "password": "password",
        "type": "list(tempur|beautyrest|serta)?"
      }
    ],
    "ergoWifiCredentials": [
      {
        "email": "email",
        "password": "password",
        "remoteStyle": "list(L|M|H)?"
      }
    ],
    "ergoMotionDevices": [
      {
        "friendlyName": "str",
        "ipAddress": "str",
        "remoteStyle": "list(L|M|H)?"
      }
    ],
    "logicdataDevices": [
      {
        "name": "str",
        "friendlyName": "str",
        "ipAddress": "str?"
      }
    ],
    "bleProxies": [
      {
        "host": "str",
        "port": "int(1,65536)?",
        "password": "password?",
        "encryptionKey": "match(^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)$)?",
        "expectedServerName": "str?"
      }
    ],
    "richmatDevices": [
      {
        "name": "str",
        "friendlyName": "str",
        "remoteCode": "str",
        "stayConnected": "bool?"
      }
    ],
    "linakDevices": [
      {
        "name": "str",
        "friendlyName": "str",
        "hasMassage": "bool?",
        "motorCount": "int?"
      }
    ],
    "solaceDevices": [
      {
        "name": "str",
        "friendlyName": "str"
      }
    ],
    "motoSleepDevices": [
      {
        "name": "str",
        "friendlyName": "str",
        "stayConnected": "bool?"
      }
    ],
    "reverieDevices": [
      {
        "name": "str",
        "friendlyName": "str"
      }
    ],
    "leggettPlattDevices": [
      {
        "name": "str",
        "friendlyName": "str"
      }
    ],
    "okimatDevices": [
      {
        "name": "str",
        "friendlyName": "str",
        "remoteCode": "str"
      }
    ],
    "keesonDevices": [
      {
        "name": "str",
        "friendlyName": "str"
      }
    ],
    "octoDevices": [
      {
        "name": "str",
        "friendlyName": "str",
        "pin": "str?"
      }
    ],
    "scannerDevices": [
      {
        "name": "str",
        "pair": "bool?"
      }
    ]
  },
  "hassio_api": true,
  "hassio_role": "default"
}